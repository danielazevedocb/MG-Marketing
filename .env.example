# =============================================================================
# MG Marketing — Exemplo de variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores.
# NUNCA versione segredos reais. Segredos ficam apenas no servidor
# (não use o prefixo NEXT_PUBLIC_* para credenciais).
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# URL pública da aplicação (usada em metadados e callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Banco de dados — Supabase PostgreSQL (via Prisma)
# Usado pela change `database-schema`. As URLs são lidas em `prisma.config.ts`
# e pelo cliente singleton (`src/lib/prisma.ts`) — apenas no servidor.
# Copie para `.env.local` e preencha com a connection string do Supabase.
# -----------------------------------------------------------------------------
# Conexão com pool (serverless/Vercel) — transaction pooler, porta 6543.
# Usuário: postgres.<PROJECT_REF> (não "postgres"). Host: confira no Dashboard
# (Connection string → Transaction pooler); sa-east-1 costuma ser aws-1-sa-east-1.
# Substitua [YOUR_DB_PASSWORD] pela senha do banco. Codifique caracteres especiais na URL.
DATABASE_URL="postgresql://postgres.zzwxzicmyrxfdstrkozj:[YOUR_DB_PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexão direta (migrations/seed e runtime PrismaPg) — porta 5432, usuário postgres
DIRECT_URL="postgresql://postgres:[YOUR_DB_PASSWORD]@db.zzwxzicmyrxfdstrkozj.supabase.co:5432/postgres?schema=public"

# -----------------------------------------------------------------------------
# Autenticação — Auth.js (change `auth-rbac`)
# -----------------------------------------------------------------------------
AUTH_SECRET="gerar-com: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Seed — usuário administrador inicial (`prisma db seed`)
# -----------------------------------------------------------------------------
# Senha do admin criado/atualizado pelo seed (bcrypt). Opcional: SEED_ADMIN_EMAIL, SEED_ADMIN_NAME.
SEED_ADMIN_PASSWORD="[YOUR_DEV_ADMIN_PASSWORD]"

# -----------------------------------------------------------------------------
# Storage de arquivos — Cloudflare R2 (change `file-storage`)
# Somente servidor — NUNCA use NEXT_PUBLIC_* para estas variáveis.
# Endpoint S3-compatible: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_PUBLIC_URL: domínio público do bucket (custom domain ou r2.dev).
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# Criptografia de credenciais de provedores de email (change `email-config`)
# -----------------------------------------------------------------------------
# Chave AES-256 (32 bytes) em base64, usada para criptografar/descriptografar
# credenciais SMTP/API no banco. Somente servidor — nunca NEXT_PUBLIC_*.
# Geração: openssl rand -base64 32
# IMPORTANTE: perder esta chave impede decriptar credenciais já salvas.
# Para rotação: decifre com a chave antiga, recifre com a nova e atualize o env.
ENCRYPTION_KEY="gerar-com: openssl rand -base64 32"

# -----------------------------------------------------------------------------
# Agendamento — runner de campanhas (change `scheduling`)
# Protege o endpoint /api/cron/schedule-runner. O Vercel Cron envia
# Authorization: Bearer <CRON_SECRET> automaticamente quando configurado.
# -----------------------------------------------------------------------------
CRON_SECRET="gerar-com: openssl rand -base64 32"
